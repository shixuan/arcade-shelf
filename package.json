{
  "name": "arcade-shelf",
  "version": "0.1.0",
  "description": "Drop-in mini canvas games as a sidebar widget — a shelf for your mini games.",
  "type": "module",
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "keywords": [
    "canvas",
    "games",
    "mini-games",
    "widget",
    "sidebar",
    "pong",
    "minesweeper"
  ],
  "author": "shixuan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shixuan/arcade-shelf.git"
  },
  "bugs": {
    "url": "https://github.com/shixuan/arcade-shelf/issues"
  },
  "homepage": "https://github.com/shixuan/arcade-shelf#readme",
  "devDependencies": {
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0"
  }
}
